generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  queued
  running
  paused
  waiting_user_action
  completed
  failed
}

model ApplicationRun {
  id             String            @id @default(cuid())
  userId         String
  jobUrl         String
  targetRole     String
  status         ApplicationStatus @default(queued)
  currentStep    String
  atsProvider    String
  retries        Int               @default(0)
  maxRetries     Int               @default(5)
  lastError      String?
  checkpointJson Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  events         ApplicationEvent[]

  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

model ApplicationEvent {
  id               String   @id @default(cuid())
  applicationRunId String
  step             String
  message          String
  payloadJson      Json?
  createdAt        DateTime @default(now())

  run ApplicationRun @relation(fields: [applicationRunId], references: [id], onDelete: Cascade)

  @@index([applicationRunId, createdAt])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  credentials      IntegrationCredential[]
  deadLetterJobs   DeadLetterJob[]
  profile          UserProfile?
}

model UserProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  education  Json     @default("[]")
  experience Json     @default("[]")
  skills     Json     @default("[]")
  projects   Json     @default("{}")
  resumeText String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IntegrationCredential {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  username          String
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model DeadLetterJob {
  id            String   @id @default(cuid())
  queueName     String
  originalJobId String
  applicationId String?
  userId        String?
  step          String?
  reason        String
  payloadJson   Json
  status        String   @default("pending")
  retryCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([queueName, status, createdAt])
}

model QueueJob {
  id        String   @id
  userId    String?  
  jobUrl    String? 
  status    String   @default("PENDING")
  steps     Json     @default("{}")
  result    Json     @default("{}")
  errors    Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
