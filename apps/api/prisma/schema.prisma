generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  queued
  running
  paused
  waiting_user_action
  completed
  failed
}

model ApplicationRun {
  id             String            @id @default(cuid())
  userId         String
  jobUrl         String
  targetRole     String
  status         ApplicationStatus @default(queued)
  currentStep    String
  atsProvider    String
  retries        Int               @default(0)
  maxRetries     Int               @default(5)
  lastError      String?
  checkpointJson Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  events         ApplicationEvent[]

  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

model ApplicationEvent {
  id               String   @id @default(cuid())
  applicationRunId String
  step             String
  message          String
  payloadJson      Json?
  createdAt        DateTime @default(now())

  run ApplicationRun @relation(fields: [applicationRunId], references: [id], onDelete: Cascade)

  @@index([applicationRunId, createdAt])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  credentials      IntegrationCredential[]
  deadLetterJobs   DeadLetterJob[]
  profile          UserProfile?
  learnedAnswers   UserLearnedAnswer[]
}

model UserProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  education  Json     @default("[]")
  experience Json     @default("[]")
  skills     Json     @default("[]")
  projects   Json     @default("{}")
  resumeText String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IntegrationCredential {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  username          String
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model DeadLetterJob {
  id            String   @id @default(cuid())
  queueName     String
  originalJobId String
  applicationId String?
  userId        String?
  step          String?
  reason        String
  payloadJson   Json
  status        String   @default("pending")
  retryCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([queueName, status, createdAt])
}

model QueueJob {
  id        String   @id
  userId    String?  
  jobUrl    String? 
  status    String   @default("PENDING")
  steps     Json     @default("{}")
  result    Json     @default("{}")
  errors    Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Stores per-question draft answers generated by the Live Apply pipeline.
/// One session per (user × job posting). Human-approved answers are persisted
/// here and loaded on the next visit to the same application URL.
///
/// v2 changes:
///  - questionsJson: array of StoredDraftEntry { questionHash, questionText, answer, approvedAt }
///  - contextFingerprint: SHA-256(confirmedSkills+jdSummary)[0:8] — used for cache invalidation
///  - draftAnswersJson kept for backwards compatibility (v1 text-keyed records)
model JobDraftSession {
  /// Deterministic ID: SHA-256(jobUrl::company::role)[0:16]
  id                 String    @id
  userId             String
  jobUrl             String
  jobTitle           String    @default("")
  companyName        String    @default("")

  /// v2: Array of { questionHash, questionText, answer, approvedAt }
  /// Primary storage for human-approved answers (hash-keyed)
  questionsJson      Json      @default("[]")

  /// v1 legacy: Map of raw question text → answer text
  /// Kept for migration; read on fallback when questionsJson is empty
  draftAnswersJson   Json      @default("{}")

  /// SHA-256(confirmedSkills + jdSummary)[0:8]
  /// Used by the cache layer to detect when context changed and invalidate
  contextFingerprint String    @default("")

  /// Set when the user manually confirms they submitted the ATS form.
  /// NULL = draft only. NOT NULL = user confirmed submission.
  submittedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, jobUrl])
  @@index([userId, contextFingerprint])
}

/// Stores highly-rated, human-approved answers globally per user for cross-job learning.
/// Acts as the learning layer for the application assistant.
model UserLearnedAnswer {
  id           String   @id @default(cuid())
  userId       String
  /// Canonical intent (e.g., "why_role", "relevant_experience")
  intent       String
  /// The original question that prompted this answer
  questionText String
  /// The refined, approved answer explicitly saved by the user
  answerText   String   @db.Text
  /// Tracks how many times this learned answer was reused in generating future answers
  useCount     Int      @default(0)
  /// Explicit evaluation score generated by V4 validation pipeline
  qualityScore Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, intent])
}
