{
  "name": "autoapply",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @autoapply/api prisma migrate dev",
    "db:generate": "pnpm --filter @autoapply/api prisma generate"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3"
  }
}
